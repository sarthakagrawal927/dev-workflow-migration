"Authorization: Bearer $TOKEN2\"); snap3=$(curl -sS \"$API_BASE/v1/feedback/by-project/$SLUG?type=feature\" -H \"Authorization: Bearer $TOKEN1\" | jq -c --arg id \"$FEATURE_ID\" '.data[]|select(.id==$id)|{upvote_count,downvote_count,viewer_vote,status}'); c7=$(curl -sS -o /tmp/s7.out -w '%{http_code}' -X PATCH \"$API_BASE/v1/feedback/$FEATURE_ID\" -H 'Content-Type: application/json' -H \"Authorization: Bearer $TOKEN1\" --data '{\"status\":\"shipped\"}'); c8=$(curl -sS -o /tmp/s8.out -w '%{http_code}' -X PATCH \"$API_BASE/v1/feedback/$FEATURE_ID\" -H 'Content-Type: application/json' -H \"Authorization: Bearer $TOKEN_OWNER\" --data '{\"status\":\"in_progress\"}'); snap4=$(curl -sS \"$API_BASE/v1/feedback/by-project/$SLUG?type=feature\" | jq -c --arg id \"$FEATURE_ID\" '.data[]|select(.id==$id)|{upvote_count,downvote_count,status}'); echo \"codes up_noauth=$c1 down_noauth=$c2 up1=$c3 up1_repeat=$c4 down1=$c5 up2=$c6 patch_non_owner=$c7 patch_owner=$c8\"; echo \"after_up $snap1\"; echo \"after_switch $snap2\"; echo \"after_up2 $snap3\"; echo \"after_status $snap4\"; echo \"body_patch_owner $(cat /tmp/s8.out)\""], decision="allow")
